# ──────────────────────────────────────────────────────────────────────────────
# Velosta Frontend — local environment
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# ──────────────────────────────────────────────────────────────────────────────

# Single backend origin (the gateway). Every API call goes through here.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Legacy — some older components fetch via Next.js API routes on the FE itself.
# Point this at the FE's own origin during dev.
NEXT_PUBLIC_URL=http://localhost:3000

# Google OAuth — must match the GOOGLE_CLIENT_ID set in BE/.env
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Maps / Places (used by /api/places, /api/places/autocomplete, /api/places/photo)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Mapbox (used by the cloud-landing 3D map and /api/directions)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: override the default site name shown in titles
NEXT_PUBLIC_SITE_NAME=Velosta
